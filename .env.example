OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=deepseek/deepseek-v3.2
OPENROUTER_APP_TITLE=Relocation Agent Course Project
# Optional: your public project URL if you want to send OpenRouter referer metadata
# OPENROUTER_HTTP_REFERER=https://your-project.example

# CLI defaults to required so that the interactive agent always uses LLM.
AGENT_LLM_MODE=required

# Optional: path to MCP provider registry config.
# Example: AGENT_MCP_CONFIG_PATH=config/mcp_connectors.json

# Optional: token for Apify hosted MCP / Actor runs.
# APIFY_TOKEN=apify_api_...
